# SUITORG - PLANTILLA DE VARIABLES DE ENTORNO
# Copia este archivo como '.env' en local
# O configura estas llaves en "Propiedades del Script" en Google Apps Script

# 1. SEGURIDAD API
API_AUTH_TOKEN=TU_TOKEN_AQUÍ

# 2. IA Y AGENTES
GEMINI_API_KEY=AIzaSy...Tu_Llave_Aquí

# 3. BASE DE DATOS (GOOGLE SHEETS)
# (Opcional si usas el script ligado directamente a la hoja)
ID_SHEET=ID_DE_TU_HOJA_AQUÍ

# 4. STRIPE PAGOS (Tarjeta de crédito/débito)
# Clave global (todos los negocios usan la misma cuenta Stripe)
# STRIPE_SECRET_KEY=sk_test_TU_CLAVE_AQUI
# STRIPE_PUB_KEY=pk_test_TU_CLAVE_AQUI
# STRIPE_WEBHOOK_SECRET=whsec_...

# O claves por negocio (multi-tenant):
# STRIPE_SECRET_KEY_NOMBREEMPRESA=sk_live_...
# STRIPE_PUB_KEY_NOMBREEMPRESA=pk_live_...

# 5. IMG DE IMAGINACION (Video desde carpeta local)
# Ruta absoluta a la carpeta que contiene las imagenes/videos para el modo IMG
# Ejemplo: MEDIA_FOLDER=C:/Users/tu/mis-archivos
MEDIA_FOLDER=C:/Users/tu/ruta/a/tus/imagenes
